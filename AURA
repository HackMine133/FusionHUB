-- 7. ЛОГИКА ВИЗУАЛИЗАТОРА РАДИУСА
-- ==========================================
local function updateVisualizer()
	if auraSettings.Enabled and auraSettings.ShowRadius then
		if not visualizer then
			visualizer = Instance.new("Part")
			visualizer.Shape = Enum.PartType.Ball
			visualizer.Material = Enum.Material.ForceField
			visualizer.Color = Color3.fromRGB(150, 255, 150)
			visualizer.Transparency = 0.8
			visualizer.Anchored = true
			visualizer.CanCollide = false
			visualizer.CastShadow = false
			visualizer.Massless = true
			visualizer.Parent = workspace
		end
		
		if not visConnection then
			visConnection = RunService.RenderStepped:Connect(function()
				local hrp = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
				if hrp and visualizer then
					visualizer.CFrame = hrp.CFrame
					visualizer.Size = Vector3.new(auraSettings.Radius * 2, auraSettings.Radius * 2, auraSettings.Radius * 2)
				end
			end)
		end
	else
		if visConnection then
			visConnection:Disconnect()
			visConnection = nil
		end
		if visualizer then
			visualizer:Destroy()
			visualizer = nil
		end
	end
end

visToggleBtn.Activated:Connect(function()
	auraSettings.ShowRadius = not auraSettings.ShowRadius
	if auraSettings.ShowRadius then
		visToggleBtn.Text = "Show Radius: ON"
		visToggleBtn.TextColor3 = Color3.fromRGB(150, 255, 150)
	else
		visToggleBtn.Text = "Show Radius: OFF"
		visToggleBtn.TextColor3 = Color3.fromRGB(200, 100, 100)
	end
	updateVisualizer()
end)

-- ==========================================
-- 8. ЛОГИКА АКТИВАЦИИ AURA
-- ==========================================
local function stopAura()
	if cacheConnection then
		task.cancel(cacheConnection)
		cacheConnection = nil
	end
	if auraConnection then
		task.cancel(auraConnection)
		auraConnection = nil
	end
	interactablesCache = {}
end

local function startAura()
	-- 1. Цикл кэширования (сканирует карту раз в 2 секунды, чтобы не лагать)
	cacheConnection = task.spawn(function()
		while auraSettings.Enabled do
			local newCache = {}
			for _, obj in ipairs(workspace:GetDescendants()) do
				if obj:IsA("ProximityPrompt") or obj:IsA("ClickDetector") then
					table.insert(newCache, obj)
				end
			end
			interactablesCache = newCache
			task.wait(2)
		end
	end)

	-- 2. Цикл взаимодействия (быстрый, зависит от Delay)
	auraConnection = task.spawn(function()
		while auraSettings.Enabled do
			local hrp = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
			if hrp then
				local targets = {}
				
				-- Фильтруем кэш по дистанции
				for _, obj in ipairs(interactablesCache) do
					if obj.Parent and obj.Parent:IsA("BasePart") then
						local dist = (hrp.Position - obj.Parent.Position).Magnitude
						if dist <= auraSettings.Radius then
							if obj:IsA("ProximityPrompt") and obj.Enabled then
								table.insert(targets, obj)
							elseif obj:IsA("ClickDetector") then
								table.insert(targets, obj)
							end
						end
					end
				end

				-- Активируем объекты
				if #targets > 0 then
					if auraSettings.Mode == "ALL" then
						for _, t in ipairs(targets) do
							pcall(function()
								if t:IsA("ProximityPrompt") and fireproximityprompt then
									fireproximityprompt(t)
								elseif t:IsA("ClickDetector") and fireclickdetector then
									fireclickdetector(t)
								end
							end)
						end
					elseif auraSettings.Mode == "RANDOM" then
						local t = targets[math.random(1, #targets)]
						pcall(function()
							if t:IsA("ProximityPrompt") and fireproximityprompt then
								fireproximityprompt(t)
							elseif t:IsA("ClickDetector") and fireclickdetector then
								fireclickdetector(t)
							end
						end)
					end
				end
			end
			task.wait(auraSettings.Delay)
		end
	end)
end

auraBtn.Activated:Connect(function()
