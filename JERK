-- 4. ЛОГИКА И АНИМАЦИИ МЕНЮ ПАРОЛЯ
-- ==========================================
local isPassOpen = false

local function togglePassMenu()
	isPassOpen = not isPassOpen
	if isPassOpen then
		passMenu.Visible = true
		passwordBox.Text = ""
		passwordBox.PlaceholderText = "Enter password..."
		TweenService:Create(passMenu, TweenInfo.new(0.3, Enum.EasingStyle.Cubic, Enum.EasingDirection.Out), {
			GroupTransparency = 0
		}):Play()
	else
		local closeTween = TweenService:Create(passMenu, TweenInfo.new(0.2, Enum.EasingStyle.Cubic, Enum.EasingDirection.In), {
			GroupTransparency = 1
		})
		closeTween:Play()
		closeTween.Completed:Wait()
		if not isPassOpen then
			passMenu.Visible = false
		end
	end
end

jerkBtn.Activated:Connect(function()
	if not isPassOpen then
		togglePassMenu()
	end
end)

closePassBtn.Activated:Connect(function()
	if isPassOpen then
		togglePassMenu()
	end
end)

-- Система перетаскивания (Drag)
local draggingPass, dragInputPass, dragStartPass, startPosPass
passMenu.InputBegan:Connect(function(input)
	if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
		draggingPass = true
		dragStartPass = input.Position
		startPosPass = passMenu.Position
		input.Changed:Connect(function()
			if input.UserInputState == Enum.UserInputState.End then draggingPass = false end
		end)
	end
end)

passMenu.InputChanged:Connect(function(input)
	if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then
		dragInputPass = input
	end
end)

UserInputService.InputChanged:Connect(function(input)
	if input == dragInputPass and draggingPass then
		local delta = input.Position - dragStartPass
		TweenService:Create(passMenu, TweenInfo.new(0.08, Enum.EasingStyle.Sine, Enum.EasingDirection.Out), {
			Position = UDim2.new(startPosPass.X.Scale, startPosPass.X.Offset + delta.X, startPosPass.Y.Scale, startPosPass.Y.Offset + delta.Y)
		}):Play()
	end
end)

