-- Функция массового обновления цветов и прозрачности
local function updateGlobalStyles()
	local color = Color3.fromRGB(HubConfig.MenuColor.R, HubConfig.MenuColor.G, HubConfig.MenuColor.B)
	
	for _, element in pairs(screenGui:GetDescendants()) do
		-- Применяем настройки фона ко всем окнам меню и настройкам
		if element:IsA("CanvasGroup") and (element.Name == "MainMenu" or element.Name:match("Settings")) then
			element.BackgroundColor3 = color
			element.BackgroundTransparency = HubConfig.BgTransparency
		end
		
		-- Применяем прозрачность кнопкам внутри списка контента
		if (element:IsA("TextButton") or element:IsA("ImageButton")) and scrollFrame and element:IsDescendantOf(scrollFrame) then
			element.BackgroundTransparency = HubConfig.BtnTransparency
		end
	end
	
	watermark.BackgroundColor3 = color
	watermark.BackgroundTransparency = HubConfig.BgTransparency
	saveConfig()
end

local function autoProcessElement(element)
	-- Подключение звуков и эффектов наведения на новые кнопки (от аддонов)
	if element:IsA("TextButton") or element:IsA("ImageButton") then
		local conn = element.Activated:Connect(playClickSound)
		table.insert(uiConnections, conn)
		
		local hoverConn1 = element.MouseEnter:Connect(function()
			TweenService:Create(element, TweenInfo.new(0.2), {BackgroundColor3 = Theme.ButtonHover}):Play()
		end)
		local hoverConn2 = element.MouseLeave:Connect(function()
			-- Если кнопка активна, не сбрасываем цвет полностью
			if not element.Name:match("Toggle") or element.BackgroundColor3 ~= Theme.ButtonActiveBg then
				TweenService:Create(element, TweenInfo.new(0.2), {
					BackgroundColor3 = element:GetAttribute("OriginalColor") or Theme.ButtonBackground
				}):Play()
			end
		end)
		table.insert(uiConnections, hoverConn1)
		table.insert(uiConnections, hoverConn2)
		
		-- Авто-применение прозрачности к кнопкам аддонов
		if scrollFrame and element:IsDescendantOf(scrollFrame) then
			element.BackgroundTransparency = HubConfig.BtnTransparency
		end
	end
	
	if element:IsA("CanvasGroup") or element:IsA("ScrollingFrame") or (element:IsA("Frame") and element.Parent == screenGui) then
		pcall(function() element.Active = true end)
		
		-- Авто-применение цвета к окнам настроек аддонов
		if element:IsA("CanvasGroup") and element.Name:match("Settings") then
			element.BackgroundColor3 = Color3.fromRGB(HubConfig.MenuColor.R, HubConfig.MenuColor.G, HubConfig.MenuColor.B)
			element.BackgroundTransparency = HubConfig.BgTransparency
		end
	end
end
screenGui.DescendantAdded:Connect(autoProcessElement)

