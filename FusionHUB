		pcall(function()
			local json = HttpService:JSONEncode(HubConfig)
			writefile(configFilename, json)
		end)
	end
end

local function loadConfig()
	if isfile and isfile(configFilename) and readfile then
		pcall(function()
			local data = HttpService:JSONDecode(readfile(configFilename))
			if data then
				if data.SoundEnabled ~= nil then HubConfig.SoundEnabled = data.SoundEnabled end
				if data.SidebarPosition then HubConfig.SidebarPosition = data.SidebarPosition end
				if data.MenuColor then HubConfig.MenuColor = data.MenuColor end
				if data.BgTransparency then HubConfig.BgTransparency = data.BgTransparency end
				if data.BtnTransparency then HubConfig.BtnTransparency = data.BtnTransparency end
			end
		end)
	end
end

