_G.FusionHub.CreateAddonSettings = function(titleText, width, height)
	local addonMenu = Instance.new("CanvasGroup")
	addonMenu.Name = titleText:gsub("%s+", "") .. "Settings"
	addonMenu.Size = UDim2.new(0, width or 250, 0, height or 200)
	addonMenu.Position = UDim2.new(0.5, 0, 0.5, 0)
	addonMenu.BackgroundColor3 = Color3.fromRGB(HubConfig.MenuColor.R, HubConfig.MenuColor.G, HubConfig.MenuColor.B)
	addonMenu.BackgroundTransparency = HubConfig.BgTransparency
	addonMenu.GroupTransparency = 1
	addonMenu.Visible = false
	addonMenu.Parent = screenGui
	Instance.new("UICorner", addonMenu).CornerRadius = Theme.CornerRadiusMain
	Instance.new("UIStroke", addonMenu).Color = Theme.StrokeColor
	
	local title = Instance.new("TextLabel")
	title.Size = UDim2.new(1, -40, 0, 30)
	title.Position = UDim2.new(0, 10, 0, 10)
	title.BackgroundTransparency = 1
	title.Text = titleText
	title.Font = Theme.FontBold
	title.TextColor3 = Theme.TextPrimary
	title.TextSize = 16
	title.TextXAlignment = Enum.TextXAlignment.Left
	title.Parent = addonMenu

	local closeBtn = Instance.new("TextButton")
	closeBtn.Size = UDim2.new(0, 30, 0, 30)
	closeBtn.Position = UDim2.new(1, -35, 0, 10)
	closeBtn.BackgroundColor3 = Theme.ButtonDangerBg
	closeBtn.BackgroundTransparency = 0.2
	closeBtn.Text = "X"
	closeBtn.Font = Theme.FontBold
	closeBtn.TextColor3 = Theme.TextPrimary
	closeBtn.TextSize = 14
	closeBtn.Parent = addonMenu
	Instance.new("UICorner", closeBtn).CornerRadius = UDim.new(0, 6)

	local isAddonMenuOpen = false
	closeBtn.Activated:Connect(function()
		isAddonMenuOpen = false
		TweenService:Create(addonMenu, TweenInfo.new(0.2, Enum.EasingStyle.Cubic, Enum.EasingDirection.In), { GroupTransparency = 1 }):Play()
		task.delay(0.2, function() if not isAddonMenuOpen then addonMenu.Visible = false end end)
	end)

	applyDragAndDropLogic(addonMenu)

	return {
		Window = addonMenu,
		CloseBtn = closeBtn,
		ToggleFunction = function()
			isAddonMenuOpen = not isAddonMenuOpen
			if isAddonMenuOpen then
				addonMenu.Visible = true
				TweenService:Create(addonMenu, TweenInfo.new(0.3, Enum.EasingStyle.Cubic, Enum.EasingDirection.Out), { GroupTransparency = 0 }):Play()
			else
				TweenService:Create(addonMenu, TweenInfo.new(0.2, Enum.EasingStyle.Cubic, Enum.EasingDirection.In), { GroupTransparency = 1 }):Play()
				task.delay(0.2, function() if not isAddonMenuOpen then addonMenu.Visible = false end end)
			end
		end
	}
end

