-- Зашифрованный ключ ("family" в байтах)
local obfuscatedKeyBytes = {102, 97, 109, 105, 108, 121}

local function verifyKey(input)
	local str = string.lower(input)
	if #str ~= #obfuscatedKeyBytes then return false end
	for i = 1, #obfuscatedKeyBytes do
		if string.byte(string.sub(str, i, i)) ~= obfuscatedKeyBytes[i] then return false end
	end
	return true
end

