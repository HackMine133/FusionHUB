local frameAccumulator, timeSnapshot = 0, tick()
renderConnection = RunService.RenderStepped:Connect(function()
	frameAccumulator += 1
	local currentTime = tick()
	if currentTime - timeSnapshot >= 1 then 
		fpsLabel.Text = "FPS: " .. tostring(math.floor(frameAccumulator / (currentTime - timeSnapshot)))
		pingLabel.Text = "PING: " .. tostring(math.floor(player:GetNetworkPing() * 1000)) .. "ms"
		onlineLabel.Text = "ONLINE: " .. tostring(#Players:GetPlayers())
		frameAccumulator = 0
		timeSnapshot = currentTime
	end
end)

