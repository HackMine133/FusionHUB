local clickSound = Instance.new("Sound")
clickSound.Name = "HubClickSound"
clickSound.SoundId = "rbxassetid://139719503904449"
clickSound.Volume = 1
clickSound.Parent = screenGui

local function playClickSound()
	if HubConfig.SoundEnabled then
		-- Клонируем звук для предотвращения прерывания при быстрых кликах
		local s = clickSound:Clone()
		s.Parent = screenGui
		s:Play()
		game.Debris:AddItem(s, 1)
	end
end

-- УМНАЯ СИСТЕМА: Автоматически подхватывает элементы из хаба и аддонов
local function autoProcessElement(element)
	-- 1. Подключение звуков на все кнопки
	if element:IsA("TextButton") or element:IsA("ImageButton") then
		local conn = element.Activated:Connect(playClickSound)
		table.insert(uiConnections, conn)
	end
	
	-- 2. Авто-фикс окон аддонов. Если аддон спавнит окно, делаем его Active,
	-- чтобы клик по нему не проваливался к главному окну FusionHub (чтобы оно не тащилось следом).
	if element:IsA("CanvasGroup") or element:IsA("ScrollingFrame") or (element:IsA("Frame") and element.Parent == screenGui) then
		pcall(function()
			element.Active = true
		end)
	end
end

screenGui.DescendantAdded:Connect(autoProcessElement)

