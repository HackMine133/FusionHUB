		isTeleporting = false
	end)
end)

-- =====================================================================
-- [ФУНКЦИЯ 3] УЛУЧШЕННЫЙ FULLBRIGHT (ПОЛНОЕ ОТСУТСТВИЕ ТЕНЕЙ)
-- =====================================================================
local weatherButton, weatherButtonText = createHubFeatureButton("DayToggleButton", "Fullbright: OFF", 3)
weatherButtonText.TextColor3 = Theme.TextSecondary

weatherButton.MouseButton1Click:Connect(function()
	isDayEnabled = not isDayEnabled
	
	if isDayEnabled then
		weatherButtonText.Text = "Fullbright: ON"
		weatherButtonText.TextColor3 = Theme.TextActive
		weatherButton.BackgroundColor3 = Theme.ButtonActiveBg
		
		dayConnection = RunService.Heartbeat:Connect(function()
			Lighting.ClockTime = 12
			Lighting.GlobalShadows = false
			Lighting.FogEnd = 1000000
			Lighting.FogStart = 1000000
			
			-- Полная яркость без теней и смещения цвета
			Lighting.Ambient = Color3.fromRGB(255, 255, 255)
			Lighting.OutdoorAmbient = Color3.fromRGB(255, 255, 255)
			
			for _, child in pairs(Lighting:GetChildren()) do
				if child:IsA("Atmosphere") then
					child.Density = 0
				end
			end
		end)
	else
		weatherButtonText.Text = "Fullbright: OFF"
		weatherButtonText.TextColor3 = Theme.TextSecondary
		weatherButton.BackgroundColor3 = Theme.ButtonBackground
		
		if dayConnection then
			dayConnection:Disconnect()
			dayConnection = nil
		end
		
		Lighting.ClockTime = originalLightingSettings.ClockTime
		Lighting.GlobalShadows = originalLightingSettings.GlobalShadows
		Lighting.FogEnd = originalLightingSettings.FogEnd
		Lighting.FogStart = originalLightingSettings.FogStart
		Lighting.Ambient = originalLightingSettings.Ambient
		Lighting.OutdoorAmbient = originalLightingSettings.OutdoorAmbient
		
		for element, density in pairs(originalAtmospheres) do
			if element and element.Parent then element.Density = density end
		end
	end
end)

