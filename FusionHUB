-- [БЛОК 12] СИСТЕМА УПРАВЛЕНИЯ ПЛАВНОЙ АНИМАЦИЕЙ
-- =====================================================================
local function playMenuCloseAnimation()
	isMenuOpen = false
	local fadeInfo = TweenInfo.new(0.25, Enum.EasingStyle.Cubic, Enum.EasingDirection.In)
	local fadeTween = TweenService:Create(menuGroup, fadeInfo, { GroupTransparency = 1 })
	local scaleTween = TweenService:Create(uiScale, fadeInfo, { Scale = 0.95 })
	
	scaleTween:Play()
	fadeTween:Play()
	fadeTween.Completed:Wait()
	
	if not isMenuOpen then menuGroup.Visible = false end
end

