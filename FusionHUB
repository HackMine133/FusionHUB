resizeGrabber.InputBegan:Connect(function(input)
	if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
		isResizingActive = true
		resizeAnchorMousePos = input.Position
		resizeAnchorMenuSize = menuGroup.AbsoluteSize
	end
end)

UserInputService.InputChanged:Connect(function(input)
	if isResizingActive and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
		local delta = input.Position - resizeAnchorMousePos
		local bWidth = math.clamp(resizeAnchorMenuSize.X + delta.X, 550, 1200)
		local bHeight = math.clamp(resizeAnchorMenuSize.Y + delta.Y, 350, 900)
		menuGroup.Size = UDim2.new(0, bWidth, 0, bHeight)
	end
end)

UserInputService.InputEnded:Connect(function(input)
	if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
		isResizingActive = false
	end
end)

