local Players = game:GetService("Players")
local RunService = game:GetService("RunService")

local player = Players.LocalPlayer

-- ==========================================
-- 1. ОЖИДАНИЕ ОСНОВНОГО ИНТЕРФЕЙСА
-- ==========================================
local playerGui = player:WaitForChild("PlayerGui")
local screenGui = playerGui:WaitForChild("FusionHubGui", 10)

if not screenGui then
	warn("FusionHub не найден! Сначала запусти основной скрипт.")
	return
end

local menuGroup = screenGui:WaitForChild("MainMenu")
local scrollFrame = menuGroup:WaitForChild("ContentScroll")

-- ==========================================
-- 2. СОЗДАНИЕ КНОПКИ WALKFLING
-- ==========================================
local flingBtn = Instance.new("TextButton")
flingBtn.Name = "WalkFlingToggleButton"
flingBtn.Size = UDim2.new(1, -15, 0, 45)
flingBtn.BackgroundColor3 = Color3.fromRGB(30, 30, 35)
flingBtn.BackgroundTransparency = 0.4
flingBtn.Text = ""
flingBtn.AutoButtonColor = true
flingBtn.LayoutOrder = 7 -- Встает после Fly
flingBtn.Parent = scrollFrame

local flingCorner = Instance.new("UICorner")
flingCorner.CornerRadius = UDim.new(0, 8)
flingCorner.Parent = flingBtn

local flingLabel = Instance.new("TextLabel")
flingLabel.Size = UDim2.new(1, -20, 1, 0)
flingLabel.Position = UDim2.new(0, 10, 0, 0)
flingLabel.BackgroundTransparency = 1
flingLabel.Text = "WalkFling: OFF"
flingLabel.Font = Enum.Font.GothamMedium
flingLabel.TextColor3 = Color3.fromRGB(240, 240, 245)
flingLabel.TextSize = 14
flingLabel.TextXAlignment = Enum.TextXAlignment.Left
flingLabel.Parent = flingBtn

-- ==========================================
-- 3. ЛОГИКА WALKFLING С ВАЙТЛИСТОМ
-- ==========================================
local isFlingEnabled = false

local function getRoot(character)
	return character and (character:FindFirstChild("HumanoidRootPart") or character:FindFirstChild("Torso") or character:FindFirstChild("UpperTorso"))
end

local function toggleFling()
	isFlingEnabled = not isFlingEnabled
	
	if isFlingEnabled then
		-- Визуальное включение
		flingLabel.Text = "WalkFling: ON"
		flingLabel.TextColor3 = Color3.fromRGB(150, 255, 150)
		flingBtn.BackgroundColor3 = Color3.fromRGB(35, 50, 35)
		
		-- Запуск встроенного Noclip, чтобы не улетать от столкновений
		task.spawn(function()
			while isFlingEnabled do
				RunService.Stepped:Wait()
				if player.Character then
					for _, v in pairs(player.Character:GetDescendants()) do
						if v:IsA("BasePart") then
							v.CanCollide = false
						end
					end
				end
			end
		end)

		-- Основной цикл WalkFling
		task.spawn(function()
			local movel = 0.1
			while isFlingEnabled do
				RunService.Heartbeat:Wait()
				
				local character = player.Character
				local root = getRoot(character)
				
				if character and character.Parent and root and root.Parent then
					
					-- =========================================
					-- ИНТЕГРАЦИЯ WHITELIST: SAFE ZONE (12 стадов)
					-- =========================================
					local isNearFriend = false
					if _G.FusionHubWhitelistEnabled and type(_G.FusionHubWhitelist) == "table" then
						for _, wlName in ipairs(_G.FusionHubWhitelist) do
							local friend = Players:FindFirstChild(wlName)
							if friend and friend.Character then
								local friendRoot = getRoot(friend.Character)
								if friendRoot and (root.Position - friendRoot.Position).Magnitude < 12 then
									isNearFriend = true
									break
								end
							end
						end
					end
					
					-- Если друг слишком близко, пропускаем разрушительный импульс в этом кадре
					if isNearFriend then continue end
					-- =========================================

					local vel = root.Velocity
					
					-- Резкий импульс для флинга
					root.Velocity = vel * 10000 + Vector3.new(0, 10000, 0)
					
					RunService.RenderStepped:Wait()
					if character and character.Parent and root and root.Parent then
						root.Velocity = vel
					end
					
					RunService.Stepped:Wait()
					if character and character.Parent and root and root.Parent then
						root.Velocity = vel + Vector3.new(0, movel, 0)
						movel = movel * -1
					end
				end
			end
		end)
	else
		-- Визуальное выключение
		flingLabel.Text = "WalkFling: OFF"
		flingLabel.TextColor3 = Color3.fromRGB(240, 240, 245)
		flingBtn.BackgroundColor3 = Color3.fromRGB(30, 30, 35)
	end
end

-- Обработка нажатия на кнопку
flingBtn.Activated:Connect(toggleFling)

-- Защита при перерождении персонажа
player.CharacterAdded:Connect(function()
	if isFlingEnabled then
		toggleFling() 
	end
end)
