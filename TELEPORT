-- 7. ЛОГИКА И АНИМАЦИИ МЕНЮ НАСТРОЕК
-- ==========================================
local isSettingsOpen = false

settingsBtn.Activated:Connect(function()
	isSettingsOpen = not isSettingsOpen
	if isSettingsOpen then
		wpMenu.Visible = true
		TweenService:Create(wpMenu, TweenInfo.new(0.3, Enum.EasingStyle.Cubic, Enum.EasingDirection.Out), {
			GroupTransparency = 0
		}):Play()
	else
		local closeTween = TweenService:Create(wpMenu, TweenInfo.new(0.2, Enum.EasingStyle.Cubic, Enum.EasingDirection.In), {
			GroupTransparency = 1
		})
		closeTween:Play()
		closeTween.Completed:Wait()
		if not isSettingsOpen then
			wpMenu.Visible = false
		end
	end
end)

-- Система перетаскивания (Drag)
local draggingWp, dragInputWp, dragStartWp, startPosWp
wpMenu.InputBegan:Connect(function(input)
	if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
		draggingWp = true
		dragStartWp = input.Position
		startPosWp = wpMenu.Position
		input.Changed:Connect(function()
			if input.UserInputState == Enum.UserInputState.End then draggingWp = false end
		end)
	end
end)

wpMenu.InputChanged:Connect(function(input)
	if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then
		dragInputWp = input
	end
end)

UserInputService.InputChanged:Connect(function(input)
	if input == dragInputWp and draggingWp then
		local delta = input.Position - dragStartWp
		TweenService:Create(wpMenu, TweenInfo.new(0.08, Enum.EasingStyle.Sine, Enum.EasingDirection.Out), {
			Position = UDim2.new(startPosWp.X.Scale, startPosWp.X.Offset + delta.X, startPosWp.Y.Scale, startPosWp.Y.Offset + delta.Y)
		}):Play()
	end
end)

