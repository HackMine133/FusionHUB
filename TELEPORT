-- 8. ЛОГИКА ТОЧКИ И ТЕЛЕПОРТА
-- ==========================================
createBtn.Activated:Connect(function()
	local char = player.Character
	if not char or not char:FindFirstChild("HumanoidRootPart") or not char:FindFirstChild("Head") then return end
	
	-- Сохраняем позицию и поворот (CFrame)
	savedCFrame = char.HumanoidRootPart.CFrame
	
	-- Удаляем старый кубик, если он был
	if waypointCube then
		waypointCube:Destroy()
	end
	
	-- Создаем визуальный кубик
	waypointCube = Instance.new("Part")
	waypointCube.Name = "FusionHubWaypoint"
	waypointCube.Size = Vector3.new(1, 1, 1)
	-- Размещаем на уровне головы
	waypointCube.Position = char.Head.Position 
	waypointCube.Anchored = true
	waypointCube.CanCollide = false
	waypointCube.Material = Enum.Material.Neon
	-- Рандомный цвет
	waypointCube.Color = Color3.new(math.random(), math.random(), math.random())
	waypointCube.Parent = workspace
	
	-- Обновляем текст на кнопке
	createBtn.Text = "Recreate a point"
end)

deleteBtn.Activated:Connect(function()
	savedCFrame = nil
	if waypointCube then
		waypointCube:Destroy()
		waypointCube = nil
	end
	createBtn.Text = "Create a point"
end)

tpBtn.Activated:Connect(function()
	if savedCFrame then
		local char = player.Character
		local hrp = char and char:FindFirstChild("HumanoidRootPart")
		
		if hrp then
			-- Телепортируем чуть выше (+3 по оси Y), чтобы игрок не застрял в текстурах
			hrp.CFrame = savedCFrame + Vector3.new(0, 3, 0)
			
			-- Визуальный отклик на кнопке
			tpLabel.TextColor3 = Color3.fromRGB(150, 255, 150)
			task.delay(0.5, function()
				tpLabel.TextColor3 = Color3.fromRGB(240, 240, 245)
			end)
		end
	else
		-- Если точка не создана, даем понять пользователю (красный текст на секунду)
		local originalText = tpLabel.Text
		tpLabel.Text = "The point has not been created!"
		tpLabel.TextColor3 = Color3.fromRGB(255, 100, 100)
		
		task.delay(1, function()
			tpLabel.Text = originalText
			tpLabel.TextColor3 = Color3.fromRGB(240, 240, 245)
		end)
	end
end)

-- Очистка кубика при уничтожении интерфейса (если игрок нажмет "Отключить скрипт")
