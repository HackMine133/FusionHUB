mBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
mBtn.TextSize = 12
mBtn.Parent = bMenu
Instance.new("UICorner", mBtn).CornerRadius = UDim.new(0, 6)

local waitBind = false
kBtn.Activated:Connect(function()
	waitBind = true
	kBtn.Text = "Press any key..."
	kBtn.TextColor3 = Color3.fromRGB(255, 200, 100)
end)

UService.InputBegan:Connect(function(inp, proc)
	if waitBind and inp.UserInputType == Enum.UserInputType.Keyboard then
		blSet.Bind = inp.KeyCode
		kBtn.Text = inp.KeyCode.Name
		kBtn.TextColor3 = Color3.fromRGB(150, 255, 150)
		waitBind = false
		return
	end
end)

mBtn.Activated:Connect(function()
	if blSet.Mode == "Hold" then
		blSet.Mode = "Toggle"
	else
		blSet.Mode = "Hold"
	end
	mBtn.Text = "Mode: " .. blSet.Mode
end)

-- 7. Логика
local function switchBlink(st)
	if blSet.Active == st then return end
	blSet.Active = st
	
	if blSet.Active then
		bLabel.Text = "Blink: ON"
		bLabel.TextColor3 = Color3.fromRGB(150, 255, 150)
		bBtn.BackgroundColor3 = Color3.fromRGB(35, 50, 35)
		bBtn:SetAttribute("OriginalColor", Color3.fromRGB(35, 50, 35))
		
		pcall(function()
			settings():GetService("NetworkSettings").IncomingReplicationLag = 99999
		end)
		
		local char = lPlayer.Character
		if char then
			char.Archivable = true
			cloneGhost = char:Clone()
			
			for _, v in pairs(cloneGhost:GetDescendants()) do
				if v:IsA("BasePart") then
					v.Material = Enum.Material.ForceField
					v.Color = Color3.fromRGB(150, 255, 150)
					v.CanCollide = false
					v.Anchored = true
				elseif v:IsA("Script") or v:IsA("LocalScript") then
					v:Destroy()
				end
			end
			cloneGhost.Parent = workspace
		end
		
	else
		bLabel.Text = "Blink: OFF"
		bLabel.TextColor3 = Color3.fromRGB(240, 240, 245)
		bBtn.BackgroundColor3 = Color3.fromRGB(30, 30, 35)
		bBtn:SetAttribute("OriginalColor", Color3.fromRGB(30, 30, 35))
		
		pcall(function()
			settings():GetService("NetworkSettings").IncomingReplicationLag = 0
		end)
		
		if cloneGhost then
			cloneGhost:Destroy()
			cloneGhost = nil
		end
	end
end

bBtn.Activated:Connect(function()
	switchBlink(not blSet.Active)
end)

UService.InputBegan:Connect(function(inp, proc)
	if proc or waitBind then return end
	
	if inp.KeyCode == blSet.Bind then
		if blSet.Mode == "Toggle" then
			switchBlink(not blSet.Active)
		elseif blSet.Mode == "Hold" then
			switchBlink(true)
		end
	end
end)

UService.InputEnded:Connect(function(inp, proc)
	if proc or waitBind then return end
	
	if inp.KeyCode == blSet.Bind and blSet.Mode == "Hold" then
		switchBlink(false)
	end
end)

lPlayer.CharacterAdded:Connect(function()
	if blSet.Active then
		switchBlink(false)
	end
end)
