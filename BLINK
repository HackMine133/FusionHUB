-- ==========================================
-- 6. МЕНЮ НАСТРОЕК BLINK
-- ==========================================
local settingsAPI = _G.FusionHub.CreateAddonSettings("Blink Settings", 250, 180)
local blinkMenu = settingsAPI.Window

