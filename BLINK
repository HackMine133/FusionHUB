local modeBtn = Instance.new("TextButton")
modeBtn.Size = UDim2.new(1, -20, 0, 35)
modeBtn.Position = UDim2.new(0, 10, 0, 125)
modeBtn.BackgroundColor3 = Color3.fromRGB(35, 35, 40)
modeBtn:SetAttribute("OriginalColor", Color3.fromRGB(35, 35, 40))
modeBtn.Text = "Mode: " .. blinkSettings.Mode
modeBtn.Font = Enum.Font.GothamBold
modeBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
modeBtn.TextSize = 12
modeBtn.Parent = blinkMenu
Instance.new("UICorner", modeBtn).CornerRadius = UDim.new(0, 6)

local isBinding = false
keybindBtn.Activated:Connect(function()
	isBinding = true
	keybindBtn.Text = "Press any key..."
	keybindBtn.TextColor3 = Color3.fromRGB(255, 200, 100)
end)

UserInputService.InputBegan:Connect(function(input, gameProcessed)
	if isBinding and input.UserInputType == Enum.UserInputType.Keyboard then
		blinkSettings.Keybind = input.KeyCode
		keybindBtn.Text = input.KeyCode.Name
		keybindBtn.TextColor3 = Color3.fromRGB(150, 255, 150)
		isBinding = false
		return
	end
end)

modeBtn.Activated:Connect(function()
	if blinkSettings.Mode == "Hold" then
		blinkSettings.Mode = "Toggle"
	else
		blinkSettings.Mode = "Hold"
	end
	modeBtn.Text = "Mode: " .. blinkSettings.Mode
end)

-- ==========================================
-- 7. ЛОГИКА BLINK
-- ==========================================
local function setBlinkState(state)
	if blinkSettings.Enabled == state then return end
	blinkSettings.Enabled = state
	
	if blinkSettings.Enabled then
		blinkLabel.Text = "Blink: ON"
		blinkLabel.TextColor3 = Color3.fromRGB(150, 255, 150)
		blinkBtn.BackgroundColor3 = Color3.fromRGB(35, 50, 35)
		blinkBtn:SetAttribute("OriginalColor", Color3.fromRGB(35, 50, 35))
		
		pcall(function()
			settings():GetService("NetworkSettings").IncomingReplicationLag = 99999
		end)
		
		local char = player.Character
		if char then
			char.Archivable = true
			ghostClone = char:Clone()
			
			for _, v in pairs(ghostClone:GetDescendants()) do
				if v:IsA("BasePart") then
					v.Material = Enum.Material.ForceField
					v.Color = Color3.fromRGB(150, 255, 150)
					v.CanCollide = false
					v.Anchored = true
				elseif v:IsA("Script") or v:IsA("LocalScript") then
					v:Destroy() 
				end
			end
			
			ghostClone.Parent = workspace
		end
		
	else
		blinkLabel.Text = "Blink: OFF"
		blinkLabel.TextColor3 = Color3.fromRGB(240, 240, 245)
		blinkBtn.BackgroundColor3 = Color3.fromRGB(30, 30, 35)
		blinkBtn:SetAttribute("OriginalColor", Color3.fromRGB(30, 30, 35))
		
		pcall(function()
			settings():GetService("NetworkSettings").IncomingReplicationLag = 0
		end)
		
		if ghostClone then
			ghostClone:Destroy()
			ghostClone = nil
		end
	end
end

blinkBtn.Activated:Connect(function()
	setBlinkState(not blinkSettings.Enabled)
end)

UserInputService.InputBegan:Connect(function(input, gameProcessed)
	if gameProcessed or isBinding then return end
	
	if input.KeyCode == blinkSettings.Keybind then
		if blinkSettings.Mode == "Toggle" then
			setBlinkState(not blinkSettings.Enabled)
		elseif blinkSettings.Mode == "Hold" then
			setBlinkState(true)
		end
	end
end)

UserInputService.InputEnded:Connect(function(input, gameProcessed)
	if gameProcessed or isBinding then return end
	
	if input.KeyCode == blinkSettings.Keybind and blinkSettings.Mode == "Hold" then
		setBlinkState(false)
	end
end)

player.CharacterAdded:Connect(function()
	if blinkSettings.Enabled then
		setBlinkState(false)
	end
end)
