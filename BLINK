keybindLabel.TextSize = 12
keybindLabel.TextXAlignment = Enum.TextXAlignment.Left
keybindLabel.Parent = blinkMenu

local keybindBtn = Instance.new("TextButton")
keybindBtn.Size = UDim2.new(1, -20, 0, 35)
keybindBtn.Position = UDim2.new(0, 10, 0, 75)
keybindBtn.BackgroundColor3 = Color3.fromRGB(15, 15, 20)
keybindBtn:SetAttribute("OriginalColor", Color3.fromRGB(15, 15, 20))
