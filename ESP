modeBtn.Activated:Connect(function()
	local availableModes = {"All", "Enemies"}
	local foundTeams = {}
	
	for _, team in ipairs(Teams:GetTeams()) do
		if not foundTeams[team.Name] then
			foundTeams[team.Name] = true
			table.insert(availableModes, "Team:" .. team.Name)
		end
	end
	for _, p in ipairs(Players:GetPlayers()) do
		if p.Team and p.Team.Name ~= "" and not foundTeams[p.Team.Name] then
			foundTeams[p.Team.Name] = true
			table.insert(availableModes, "Team:" .. p.Team.Name)
		end
	end
	table.insert(availableModes, "Target")
	
	local currentIndex = table.find(availableModes, espSettings.Mode) or 1
	local nextIndex = (currentIndex % #availableModes) + 1
	local newMode = availableModes[nextIndex]
	
	espSettings.Mode = newMode
	targetBox.Visible = (newMode == "Target")
	
	if newMode == "All" then modeBtn.Text = "Mode: All"
	elseif newMode == "Enemies" then modeBtn.Text = "Mode: Enemies"
	elseif newMode == "Target" then modeBtn.Text = "Mode: Target"
	else modeBtn.Text = "Команда: " .. string.sub(newMode, 6) end
	
	local height = 290
	if targetBox.Visible then height = height + 43 end
	if espSettings.WallCheck then height = height + 56 end
	TweenService:Create(espMenu, TweenInfo.new(0.2), {Size = UDim2.new(0, 260, 0, height)}):Play()
