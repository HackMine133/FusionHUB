local isSettingsOpen = false

settingsBtn.Activated:Connect(function()
	isSettingsOpen = not isSettingsOpen
	if isSettingsOpen then
		espMenu.Visible = true
		TweenService:Create(espMenu, TweenInfo.new(0.3, Enum.EasingStyle.Cubic, Enum.EasingDirection.Out), {
			GroupTransparency = 0
		}):Play()
	else
		local closeTween = TweenService:Create(espMenu, TweenInfo.new(0.2, Enum.EasingStyle.Cubic, Enum.EasingDirection.In), {
			GroupTransparency = 1
		})
		closeTween:Play()
		closeTween.Completed:Wait()
		if not isSettingsOpen then
			espMenu.Visible = false
		end
	end
end)

-- Система перетаскивания (Drag) для меню настроек ESP
local draggingEsp, dragInputEsp, dragStartEsp, startPosEsp
espMenu.InputBegan:Connect(function(input)
	if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
		draggingEsp = true
		dragStartEsp = input.Position
		startPosEsp = espMenu.Position
		input.Changed:Connect(function()
			if input.UserInputState == Enum.UserInputState.End then draggingEsp = false end
		end)
	end
end)

espMenu.InputChanged:Connect(function(input)
	if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then
		dragInputEsp = input
	end
end)

UserInputService.InputChanged:Connect(function(input)
	if input == dragInputEsp and draggingEsp then
		local delta = input.Position - dragStartEsp
		TweenService:Create(espMenu, TweenInfo.new(0.08, Enum.EasingStyle.Sine, Enum.EasingDirection.Out), {
			Position = UDim2.new(startPosEsp.X.Scale, startPosEsp.X.Offset + delta.X, startPosEsp.Y.Scale, startPosEsp.Y.Offset + delta.Y)
		}):Play()
	end
end)

-- Улучшенная логика смены режимов: Ищем команды везде
modeBtn.Activated:Connect(function()
	local availableModes = {"All"}
	local foundTeams = {} -- Таблица для исключения дубликатов
	
	-- 1. Сначала пытаемся получить из стандартного сервиса Teams
	for _, team in ipairs(Teams:GetTeams()) do
		if not foundTeams[team.Name] then
			foundTeams[team.Name] = true
			table.insert(availableModes, "Team:" .. team.Name)
		end
	end
	
	-- 2. Надежный фоллбэк: ищем команды прямо у игроков на сервере
	for _, p in ipairs(Players:GetPlayers()) do
		if p.Team and p.Team.Name ~= "" then
			if not foundTeams[p.Team.Name] then
				foundTeams[p.Team.Name] = true
				table.insert(availableModes, "Team:" .. p.Team.Name)
			end
		end
	end
	
	table.insert(availableModes, "Target") -- В конце всегда добавляем поиск по цели
	
	-- Ищем текущий индекс
	local currentIndex = 1
	for i, mode in ipairs(availableModes) do
		if mode == espSettings.Mode then
			currentIndex = i
			break
		end
	end
	
	-- Переключаем на следующий индекс (или сбрасываем на 1, если дошли до конца)
	local nextIndex = currentIndex + 1
	if nextIndex > #availableModes then
		nextIndex = 1
	end
	
	local newMode = availableModes[nextIndex]
	espSettings.Mode = newMode
	
	-- Обновляем визуал кнопки
	if newMode == "All" then
		modeBtn.Text = "Mode: All"
		targetBox.Visible = false
	elseif newMode == "Target" then
		modeBtn.Text = "Mode: Target"
		targetBox.Visible = true
	elseif string.sub(newMode, 1, 5) == "Team:" then
		local teamName = string.sub(newMode, 6)
		modeBtn.Text = "Команда: " .. teamName
		targetBox.Visible = false
	end
end)

targetBox.FocusLost:Connect(function()
	espSettings.TargetName = string.lower(targetBox.Text)
end)

