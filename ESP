-- 6. ФУНКЦИОНАЛ ПОДСВЕТКИ И RAYCAST
-- ==========================================
local function clearESP()
	for p, highlight in pairs(espObjects) do
		if highlight then highlight:Destroy() end
	end
	table.clear(espObjects)
	espFolder:ClearAllChildren()
end

local function isCharacterVisible(targetChar)
	local camera = workspace.CurrentCamera
	local origin = camera.CFrame.Position
	
	-- Умный поиск части для проверки видимости
	local targetPart = targetChar.PrimaryPart or targetChar:FindFirstChild("HumanoidRootPart") or targetChar:FindFirstChild("Head") or targetChar:FindFirstChildWhichIsA("BasePart")
	
	if not targetPart then return false end
	
	local direction = (targetPart.Position - origin)
	local rayParams = RaycastParams.new()
	rayParams.FilterType = Enum.RaycastFilterType.Exclude
	rayParams.FilterDescendantsInstances = {camera, player.Character}
	rayParams.IgnoreWater = true
	
	local result = workspace:Raycast(origin, direction.Unit * (direction.Magnitude + 1), rayParams)
	
	if result and result.Instance and result.Instance:IsDescendantOf(targetChar) then
		return true
	end
	
	return false 
end

local function updateESP()
	if not espSettings.Enabled then
		clearESP()
		return
	end

	for _, v in pairs(Players:GetPlayers()) do
		if v ~= player then
			local char = v.Character
			-- Гибкий поиск: не полагаемся только на стандартные названия
			local humanoid = char and char:FindFirstChildWhichIsA("Humanoid")
			local primaryPart = char and (char.PrimaryPart or char:FindFirstChild("HumanoidRootPart") or char:FindFirstChildWhichIsA("BasePart"))
			
			local isAlive = true
			if humanoid then 
				isAlive = humanoid.Health > 0 
			end
			
			if char and primaryPart and isAlive then
				local shouldHighlight = false
				
				if espSettings.Mode == "All" then
					shouldHighlight = true
				elseif espSettings.Mode == "Enemies" then
					if player.Team == nil or v.Team ~= player.Team then shouldHighlight = true end
				elseif string.sub(espSettings.Mode, 1, 5) == "Team:" then
					local targetTeamName = string.sub(espSettings.Mode, 6)
					if v.Team and v.Team.Name == targetTeamName then shouldHighlight = true end
				elseif espSettings.Mode == "Target" then
					if espSettings.TargetName ~= "" then
						local nameLower = string.lower(v.Name)
						local displayLower = string.lower(v.DisplayName)
						if string.find(nameLower, espSettings.TargetName) or string.find(displayLower, espSettings.TargetName) then
							shouldHighlight = true
						end
					end
				end
				
				if shouldHighlight then
					local highlight = espObjects[v]
					
					if not highlight or not highlight:IsDescendantOf(game) then
						if highlight then highlight:Destroy() end
						highlight = Instance.new("Highlight")
						highlight.Name = "FusionESP_" .. v.Name
						highlight.FillTransparency = 0.5
						highlight.OutlineTransparency = 0.1
						highlight.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
						
						-- ОБХОД АНТИЧИТА: привязываем через Adornee из безопасной папки
						highlight.Adornee = char
						highlight.Parent = espFolder 
						
						espObjects[v] = highlight
					end
					
					local activeColor = espSettings.Color
					
					if espSettings.WallCheck then
						if isCharacterVisible(char) then
							activeColor = espSettings.VisibleColor
						end
					end
					
					highlight.FillColor = activeColor
					highlight.OutlineColor = Color3.fromRGB(255, 255, 255)
					
					-- Защита на случай, если игра регенерировала персонажа
					if highlight.Adornee ~= char then highlight.Adornee = char end
				else
					if espObjects[v] then
						espObjects[v]:Destroy()
						espObjects[v] = nil
					end
				end
			else
				if espObjects[v] then
					espObjects[v]:Destroy()
					espObjects[v] = nil
				end
			end
		end
	end
end

espBtn.Activated:Connect(function()
