-- 7. ФУНКЦИОНАЛ ПОДСВЕТКИ (ESP)
-- ==========================================
local function clearESP()
	for p, highlight in pairs(espObjects) do
		if highlight then highlight:Destroy() end
	end
	table.clear(espObjects)
end

local function updateESP()
	if not espSettings.Enabled then
		clearESP()
		return
	end

	for _, v in pairs(Players:GetPlayers()) do
		if v ~= player then
			local char = v.Character
			local humanoid = char and char:FindFirstChildOfClass("Humanoid")
			local hrp = char and char:FindFirstChild("HumanoidRootPart")
			
			if char and hrp and humanoid and humanoid.Health > 0 then
				local shouldHighlight = false
				
				-- Проверка условий фильтрации
				if espSettings.Mode == "All" then
					shouldHighlight = true
					
				elseif string.sub(espSettings.Mode, 1, 5) == "Team:" then
					-- Проверяем принадлежность к выбранной команде
					local targetTeamName = string.sub(espSettings.Mode, 6)
					if v.Team and v.Team.Name == targetTeamName then
						shouldHighlight = true
					end
					
				elseif espSettings.Mode == "Target" then
					if espSettings.TargetName ~= "" then
						local nameLower = string.lower(v.Name)
						local displayLower = string.lower(v.DisplayName)
						if string.find(nameLower, espSettings.TargetName) or string.find(displayLower, espSettings.TargetName) then
							shouldHighlight = true
						end
					end
				end
				
				-- Применение или удаление Highlight эффекта
				if shouldHighlight then
					local highlight = espObjects[v]
					
					-- Пересоздаем, если объект был удален движком
					if not highlight or not highlight:IsDescendantOf(game) then
						if highlight then highlight:Destroy() end
						highlight = Instance.new("Highlight")
						highlight.Name = "FusionESP"
						highlight.FillTransparency = 0.5
						highlight.OutlineTransparency = 0.1
						highlight.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
						highlight.Parent = char
						espObjects[v] = highlight
					end
					
					-- Обновляем динамические свойства
					highlight.FillColor = espSettings.Color
					highlight.OutlineColor = Color3.fromRGB(255, 255, 255)
					if highlight.Parent ~= char then
						highlight.Parent = char
					end
				else
					if espObjects[v] then
						espObjects[v]:Destroy()
						espObjects[v] = nil
					end
				end
			else
				-- Если персонаж умер, вышел или удалился из игры
				if espObjects[v] then
					espObjects[v]:Destroy()
					espObjects[v] = nil
				end
			end
		end
	end
end

-- Обработка включения / выключения по кнопке
espBtn.Activated:Connect(function()
	espSettings.Enabled = not espSettings.Enabled
	
	if espSettings.Enabled then
		espLabel.Text = "ESP: ON"
		espLabel.TextColor3 = Color3.fromRGB(150, 255, 150)
		espBtn.BackgroundColor3 = Color3.fromRGB(35, 50, 35)
		
		-- Привязываем безопасный цикл обновления
		espConnection = RunService.Heartbeat:Connect(updateESP)
	else
		espLabel.Text = "ESP: OFF"
		espLabel.TextColor3 = Color3.fromRGB(240, 240, 245)
		espBtn.BackgroundColor3 = Color3.fromRGB(30, 30, 35)
		
		if espConnection then
			espConnection:Disconnect()
			espConnection = nil
		end
		clearESP()
	end
end)

