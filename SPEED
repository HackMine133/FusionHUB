local presetsLabel = Instance.new("TextLabel")
presetsLabel.Size = UDim2.new(1, 0, 0, 20)
presetsLabel.Position = UDim2.new(0, 0, 0, 95)
presetsLabel.BackgroundTransparency = 1
presetsLabel.Text = "Quick Settings:"
presetsLabel.Font = Enum.Font.Gotham
presetsLabel.TextColor3 = Color3.fromRGB(180, 180, 185)
presetsLabel.TextSize = 12
presetsLabel.Parent = speedMenu

-- Контейнер для быстрых скоростей
local speedsFrame = Instance.new("Frame")
speedsFrame.Size = UDim2.new(1, -20, 0, 35)
speedsFrame.Position = UDim2.new(0, 10, 0, 120)
speedsFrame.BackgroundTransparency = 1
speedsFrame.Parent = speedMenu

local speedsLayout = Instance.new("UIListLayout")
speedsLayout.FillDirection = Enum.FillDirection.Horizontal
speedsLayout.HorizontalAlignment = Enum.HorizontalAlignment.Center
speedsLayout.Padding = UDim.new(0, 8)
speedsLayout.Parent = speedsFrame

local function createSpeedBtn(speedValue, displayName)
	local btn = Instance.new("TextButton")
	btn.Size = UDim2.new(0, 45, 0, 30)
	btn.BackgroundColor3 = Color3.fromRGB(30, 30, 35)
	btn.Text = displayName
	btn.Font = Enum.Font.GothamBold
	btn.TextColor3 = Color3.fromRGB(255, 255, 255)
	btn.TextSize = 12
	btn.Parent = speedsFrame
	
	local btnRound = Instance.new("UICorner")
	btnRound.CornerRadius = UDim.new(0, 6)
	btnRound.Parent = btn
	
	btn.Activated:Connect(function()
		speedSettings.TargetSpeed = speedValue
		speedBox.Text = tostring(speedValue)
	end)
end

-- Кнопки пресетов скорости
createSpeedBtn(25, "Jog")
createSpeedBtn(50, "Fast")
createSpeedBtn(100, "Zoom")
createSpeedBtn(250, "God")

-- ==========================================
-- 7. ЛОГИКА СКОРОСТИ (SPEED HACK)
-- ==========================================
local function toggleSpeed()
	speedSettings.Enabled = not speedSettings.Enabled
	
	local char = player.Character
	local humanoid = char and char:FindFirstChildOfClass("Humanoid")
	
	if speedSettings.Enabled then
		-- Визуальное включение
		speedLabel.Text = "Speed: ON"
		speedLabel.TextColor3 = Color3.fromRGB(150, 255, 150)
		speedBtn.BackgroundColor3 = Color3.fromRGB(35, 50, 35)
		-- Устанавливаем атрибут, чтобы hover ядра восстанавливал правильный цвет
		speedBtn:SetAttribute("OriginalColor", Color3.fromRGB(35, 50, 35))
		
		if humanoid then
			originalSpeed = humanoid.WalkSpeed
		end
		
		speedConnection = RunService.Heartbeat:Connect(function()
			local currentHumanoid = player.Character and player.Character:FindFirstChildOfClass("Humanoid")
			if currentHumanoid and currentHumanoid.WalkSpeed ~= speedSettings.TargetSpeed then
				currentHumanoid.WalkSpeed = speedSettings.TargetSpeed
			end
		end)
		
	else
		-- Визуальное выключение
		speedLabel.Text = "Speed: OFF"
		speedLabel.TextColor3 = Color3.fromRGB(240, 240, 245)
		speedBtn.BackgroundColor3 = Color3.fromRGB(30, 30, 35)
		speedBtn:SetAttribute("OriginalColor", Color3.fromRGB(30, 30, 35))
		
		if speedConnection then
			speedConnection:Disconnect()
			speedConnection = nil
		end
		
		if humanoid then
			humanoid.WalkSpeed = originalSpeed
		end
	end
end

speedBtn.Activated:Connect(toggleSpeed)

-- Защита от багов при перерождении персонажа
player.CharacterAdded:Connect(function(newChar)
	local humanoid = newChar:WaitForChild("Humanoid", 5)
	if humanoid then
		if not speedSettings.Enabled then
			originalSpeed = humanoid.WalkSpeed
		end
	end
end)
