-- ==========================================
-- 6. ИСПОЛЬЗОВАНИЕ GLOBAL API ДЛЯ МЕНЮ НАСТРОЕК
-- ==========================================
-- Генерируем окно через встроенную функцию хаба (включает "X" кнопку, стили и Drag&Drop)
local settingsAPI = _G.FusionHub.CreateAddonSettings("Speed Settings", 250, 180)
local speedMenu = settingsAPI.Window

-- Привязываем шестеренку к функции открытия/закрытия окна
settingsBtn.Activated:Connect(settingsAPI.ToggleFunction)

-- Поле ввода скорости (добавляем внутрь сгенерированного окна)
local speedBox = Instance.new("TextBox")
speedBox.Size = UDim2.new(1, -20, 0, 35)
speedBox.Position = UDim2.new(0, 10, 0, 50)
speedBox.BackgroundColor3 = Color3.fromRGB(15, 15, 20)
speedBox.PlaceholderText = "Enter a number (Default: 16)"
speedBox.Text = tostring(speedSettings.TargetSpeed)
speedBox.Font = Enum.Font.Gotham
speedBox.TextColor3 = Color3.fromRGB(255, 255, 255)
speedBox.TextSize = 13
speedBox.Parent = speedMenu

local speedBoxCorner = Instance.new("UICorner")
speedBoxCorner.CornerRadius = UDim.new(0, 6)
speedBoxCorner.Parent = speedBox

local speedBoxStroke = Instance.new("UIStroke")
speedBoxStroke.Color = Color3.fromRGB(80, 80, 90)
speedBoxStroke.Parent = speedBox

-- Обновление скорости из поля ввода
speedBox.FocusLost:Connect(function()
	local num = tonumber(speedBox.Text)
	if num then
		speedSettings.TargetSpeed = num
	else
		speedBox.Text = tostring(speedSettings.TargetSpeed)
	end
end)

