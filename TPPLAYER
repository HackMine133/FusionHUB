-- 8. ЛОГИКА МЕНЮ И АНИМАЦИИ
-- ==========================================
local isSettingsOpen = false

local function closeTpMenu()
	if not isSettingsOpen then return end
	isSettingsOpen = false
	local closeTween = TweenService:Create(tpMenu, TweenInfo.new(0.2, Enum.EasingStyle.Cubic, Enum.EasingDirection.In), {
		GroupTransparency = 1
	})
	closeTween:Play()
	closeTween.Completed:Wait()
	if not isSettingsOpen then
		tpMenu.Visible = false
	end
end

settingsBtn.Activated:Connect(function()
	isSettingsOpen = not isSettingsOpen
	if isSettingsOpen then
		refreshPlayerList() -- Обновляем список перед открытием
		tpMenu.Visible = true
		TweenService:Create(tpMenu, TweenInfo.new(0.3, Enum.EasingStyle.Cubic, Enum.EasingDirection.Out), {
			GroupTransparency = 0
		}):Play()
	else
		closeTpMenu()
	end
end)

saveBtn.Activated:Connect(closeTpMenu)

-- Система перетаскивания (Drag)
local draggingTp, dragInputTp, dragStartTp, startPosTp
tpMenu.InputBegan:Connect(function(input)
	if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
		draggingTp = true
		dragStartTp = input.Position
		startPosTp = tpMenu.Position
		input.Changed:Connect(function()
			if input.UserInputState == Enum.UserInputState.End then draggingTp = false end
		end)
	end
end)

tpMenu.InputChanged:Connect(function(input)
	if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then
		dragInputTp = input
	end
end)

UserInputService.InputChanged:Connect(function(input)
	if input == dragInputTp and draggingTp then
		local delta = input.Position - dragStartTp
		TweenService:Create(tpMenu, TweenInfo.new(0.08, Enum.EasingStyle.Sine, Enum.EasingDirection.Out), {
			Position = UDim2.new(startPosTp.X.Scale, startPosTp.X.Offset + delta.X, startPosTp.Y.Scale, startPosTp.Y.Offset + delta.Y)
		}):Play()
	end
end)

-- ==========================================
-- 9. ЛОГИКА ТЕЛЕПОРТАЦИИ
-- ==========================================
tpBtn.Activated:Connect(function()
	if not selectedPlayerName then
		warn("Игрок для телепортации не выбран!")
		-- Визуальная подсказка (красный текст)
		local oldColor = tpLabel.TextColor3
		tpLabel.TextColor3 = Color3.fromRGB(255, 100, 100)
		task.delay(0.5, function()
			tpLabel.TextColor3 = oldColor
		end)
		return
	end
	
	local targetPlayer = Players:FindFirstChild(selectedPlayerName)
	if targetPlayer and targetPlayer.Character and targetPlayer.Character:FindFirstChild("HumanoidRootPart") then
		local myChar = player.Character
		if myChar and myChar:FindFirstChild("HumanoidRootPart") then
			-- Телепортируем немного за спину/выше игрока, чтобы не застрять в нем
			local targetCFrame = targetPlayer.Character.HumanoidRootPart.CFrame
			myChar.HumanoidRootPart.CFrame = targetCFrame * CFrame.new(0, 2, 3)
			
			-- Анимация успешного нажатия (подсветка зеленым на секунду)
			local oldColor = tpBtn.BackgroundColor3
			tpBtn.BackgroundColor3 = Color3.fromRGB(45, 120, 45)
			task.delay(0.2, function()
				TweenService:Create(tpBtn, TweenInfo.new(0.5), {BackgroundColor3 = oldColor}):Play()
			end)
		end
	else
		warn("Игрок мертв, вышел или не загрузился.")
		local oldColor = tpLabel.TextColor3
		tpLabel.TextColor3 = Color3.fromRGB(255, 100, 100)
		tpLabel.Text = "Target Unavailable!"
		task.delay(1, function()
			tpLabel.TextColor3 = oldColor
			tpLabel.Text = "Teleport to: " .. (selectedPlayerName or "None")
		end)
	end
end)
