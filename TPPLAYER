-- ==========================================
-- 5. КНОПКА НАСТРОЕК (ШЕСТЕРЕНКА)
-- ==========================================
local settingsBtn = Instance.new("ImageButton")
settingsBtn.Name = "TPSettingsButton"
settingsBtn.Size = UDim2.new(0, 45, 0, 45)
settingsBtn.Position = UDim2.new(1, -45, 0, 0)
settingsBtn.BackgroundColor3 = Color3.fromRGB(30, 30, 35)
settingsBtn.BackgroundTransparency = 0.4
settingsBtn.AutoButtonColor = true
settingsBtn.Active = true
settingsBtn.Parent = tpRow

local settingsCorner = Instance.new("UICorner")
settingsCorner.CornerRadius = UDim.new(0, 8)
settingsCorner.Parent = settingsBtn

local settingsIcon = Instance.new("ImageLabel")
settingsIcon.Size = UDim2.new(0.6, 0, 0.6, 0)
settingsIcon.Position = UDim2.new(0.5, 0, 0.5, 0)
settingsIcon.AnchorPoint = Vector2.new(0.5, 0.5)
settingsIcon.BackgroundTransparency = 1
settingsIcon.Image = "rbxassetid://9405931578" -- Иконка шестеренки
settingsIcon.Parent = settingsBtn

-- ==========================================
-- 6. МЕНЮ НАСТРОЕК (ИСПОЛЬЗУЕМ ВСТРОЕННЫЙ API FUSIONHUB)
-- ==========================================
-- Фабрика автоматически создает окно в стиле хаба, с кнопкой "Х" и настроенным Drag & Drop
local settingsAPI = _G.FusionHub.CreateAddonSettings("Select Player", 260, 320)
local tpMenu = settingsAPI.Window

-- Кнопка обновления списка (сдвинута левее, чтобы не закрывать встроенный крестик)
local refreshBtn = Instance.new("TextButton")
refreshBtn.Size = UDim2.new(0, 60, 0, 24)
refreshBtn.Position = UDim2.new(1, -105, 0, 13)
refreshBtn.BackgroundColor3 = Color3.fromRGB(35, 35, 40)
refreshBtn.Text = "Refresh"
refreshBtn.Font = Enum.Font.Gotham
refreshBtn.TextColor3 = Color3.fromRGB(200, 200, 200)
refreshBtn.TextSize = 12
refreshBtn.Parent = tpMenu
Instance.new("UICorner", refreshBtn).CornerRadius = UDim.new(0, 6)

-- Скролл-фрейм для списка игроков
local playerScroll = Instance.new("ScrollingFrame")
playerScroll.Size = UDim2.new(1, -20, 1, -100)
playerScroll.Position = UDim2.new(0, 10, 0, 50)
playerScroll.BackgroundTransparency = 1
playerScroll.BorderSizePixel = 0
playerScroll.ScrollBarThickness = 4
playerScroll.ScrollBarImageColor3 = Color3.fromRGB(255, 255, 255)
playerScroll.ScrollBarImageTransparency = 0.5
playerScroll.CanvasSize = UDim2.new(0, 0, 0, 0)
playerScroll.AutomaticCanvasSize = Enum.AutomaticSize.Y
playerScroll.Parent = tpMenu

local playerLayout = Instance.new("UIListLayout")
playerLayout.Padding = UDim.new(0, 5)
playerLayout.Parent = playerScroll

-- Дополнительная кнопка "Save & Close" внизу окна
local saveBtn = Instance.new("TextButton")
saveBtn.Size = UDim2.new(1, -20, 0, 35)
saveBtn.Position = UDim2.new(0, 10, 1, -45)
saveBtn.BackgroundColor3 = Color3.fromRGB(45, 120, 45)
saveBtn.Text = "Save & Close"
