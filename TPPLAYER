saveBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
saveBtn.TextSize = 14
saveBtn.Parent = tpMenu
Instance.new("UICorner", saveBtn).CornerRadius = UDim.new(0, 6)

-- ==========================================
-- 7. ЛОГИКА СПИСКА ИГРОКОВ
-- ==========================================
local function refreshPlayerList()
	for _, child in pairs(playerScroll:GetChildren()) do
		if child:IsA("TextButton") then
			child:Destroy()
		end
	end
	
	for _, p in pairs(Players:GetPlayers()) do
		if p ~= player then
			local btn = Instance.new("TextButton")
			btn.Size = UDim2.new(1, -10, 0, 36)
			
			local baseBg = Color3.fromRGB(30, 30, 35)
			local teamBg = p.Team and p.TeamColor.Color or baseBg
			btn.BackgroundColor3 = baseBg:Lerp(teamBg, 0.3)
			
			btn.Text = p.DisplayName .. " (@" .. p.Name .. ")"
			btn.Font = Enum.Font.Gotham
			btn.TextColor3 = Color3.fromRGB(200, 200, 205)
			btn.TextSize = 13
			btn.TextXAlignment = Enum.TextXAlignment.Left
			btn.Parent = playerScroll
			Instance.new("UICorner", btn).CornerRadius = UDim.new(0, 6)
			
			local padding = Instance.new("UIPadding")
			padding.PaddingLeft = UDim.new(0, 40)
			padding.Parent = btn
			
			local avatar = Instance.new("ImageLabel")
			avatar.Size = UDim2.new(0, 26, 0, 26)
			avatar.Position = UDim2.new(0, -32, 0.5, -13)
			avatar.BackgroundTransparency = 1
			avatar.BackgroundColor3 = Color3.fromRGB(20, 20, 25)
			
			pcall(function()
				avatar.Image = Players:GetUserThumbnailAsync(p.UserId, Enum.ThumbnailType.HeadShot, Enum.ThumbnailSize.Size48x48)
			end)
			avatar.Parent = btn
			Instance.new("UICorner", avatar).CornerRadius = UDim.new(1, 0)
			
			if selectedPlayerName == p.Name then
				local highlight = Instance.new("UIStroke")
				highlight.Color = Color3.fromRGB(150, 255, 150)
				highlight.Thickness = 1.5
				highlight.Parent = btn
				btn.TextColor3 = Color3.fromRGB(255, 255, 255)
			end
			
			btn.Activated:Connect(function()
				selectedPlayerName = p.Name
				tpLabel.Text = "Teleport to: " .. p.DisplayName
				refreshPlayerList() 
			end)
		end
	end
	
	local randomBtn = Instance.new("TextButton")
	randomBtn.Size = UDim2.new(1, -10, 0, 36)
	randomBtn.BackgroundColor3 = Color3.fromRGB(45, 45, 60)
	randomBtn.Text = "🎲 RANDOM PLAYER"
	randomBtn.Font = Enum.Font.GothamBold
	randomBtn.TextColor3 = Color3.fromRGB(255, 215, 0)
	randomBtn.TextSize = 13
	randomBtn.LayoutOrder = 9999 
	randomBtn.Parent = playerScroll
	Instance.new("UICorner", randomBtn).CornerRadius = UDim.new(0, 6)
	
	if selectedPlayerName == "RANDOM" then
		local highlight = Instance.new("UIStroke")
		highlight.Color = Color3.fromRGB(255, 215, 0)
		highlight.Thickness = 1.5
		highlight.Parent = randomBtn
	end
	
	randomBtn.Activated:Connect(function()
		selectedPlayerName = "RANDOM"
		tpLabel.Text = "Teleport to: RANDOM"
		refreshPlayerList()
	end)
end

refreshBtn.Activated:Connect(refreshPlayerList)

-- ==========================================
-- 8. ЛОГИКА МЕНЮ (ИСПРАВЛЕННАЯ АНИМАЦИЯ)
-- ==========================================
-- Теперь анимация обрабатывается стабильным ToggleFunction из ядра
settingsBtn.Activated:Connect(function()
	if not tpMenu.Visible then
		refreshPlayerList() -- Обновляем только перед открытием
	end
	settingsAPI.ToggleFunction()
end)

saveBtn.Activated:Connect(function()
	if tpMenu.Visible then
		settingsAPI.ToggleFunction()
	end
end)

-- ==========================================
-- 9. ЛОГИКА ТЕЛЕПОРТАЦИИ
-- ==========================================
tpBtn.Activated:Connect(function()
	if not selectedPlayerName then
		warn("Игрок для телепортации не выбран!")
		local oldColor = tpLabel.TextColor3
		tpLabel.TextColor3 = Color3.fromRGB(255, 100, 100)
		task.delay(0.5, function()
			tpLabel.TextColor3 = oldColor
		end)
		return
	end
	
	local targetPlayer = nil
	
	if selectedPlayerName == "RANDOM" then
		local validPlayers = {}
		for _, p in pairs(Players:GetPlayers()) do
			if p ~= player and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
				table.insert(validPlayers, p)
			end
		end
		
		if #validPlayers > 0 then
			targetPlayer = validPlayers[math.random(1, #validPlayers)]
		end
	else
		targetPlayer = Players:FindFirstChild(selectedPlayerName)
	end

	if targetPlayer and targetPlayer.Character and targetPlayer.Character:FindFirstChild("HumanoidRootPart") then
		local myChar = player.Character
		if myChar and myChar:FindFirstChild("HumanoidRootPart") then
			local targetCFrame = targetPlayer.Character.HumanoidRootPart.CFrame
			myChar.HumanoidRootPart.CFrame = targetCFrame * CFrame.new(0, 2, 3)
			
			local oldColor = tpBtn.BackgroundColor3
			tpBtn.BackgroundColor3 = Color3.fromRGB(45, 120, 45)
			task.delay(0.2, function()
				TweenService:Create(tpBtn, TweenInfo.new(0.5), {BackgroundColor3 = oldColor}):Play()
			end)
		end
	else
		warn("Игрок мертв, вышел, не загрузился или сервер пуст.")
		local oldColor = tpLabel.TextColor3
		tpLabel.TextColor3 = Color3.fromRGB(255, 100, 100)
		tpLabel.Text = "Target Unavailable!"
		task.delay(1, function()
			tpLabel.TextColor3 = oldColor
			tpLabel.Text = "Teleport to: " .. (selectedPlayerName or "None")
		end)
	end
end)
