-- ==========================================
-- 7. ЛОГИКА СПИСКА ИГРОКОВ
-- ==========================================
local function refreshPlayerList()
	-- Очищаем старый список
	for _, child in pairs(playerScroll:GetChildren()) do
		if child:IsA("TextButton") then
			child:Destroy()
		end
	end
	
	-- Добавляем текущих игроков
	for _, p in pairs(Players:GetPlayers()) do
		if p ~= player then -- Исключаем самих себя
			local btn = Instance.new("TextButton")
			btn.Size = UDim2.new(1, -10, 0, 30)
			btn.BackgroundColor3 = Color3.fromRGB(30, 30, 35)
			btn.Text = p.DisplayName .. " (@" .. p.Name .. ")"
			btn.Font = Enum.Font.Gotham
			btn.TextColor3 = Color3.fromRGB(200, 200, 205)
			btn.TextSize = 13
			btn.Parent = playerScroll
			Instance.new("UICorner", btn).CornerRadius = UDim.new(0, 6)
			
			-- Выделяем, если он уже был выбран
			if selectedPlayerName == p.Name then
				btn.BackgroundColor3 = Color3.fromRGB(50, 70, 50)
				btn.TextColor3 = Color3.fromRGB(150, 255, 150)
			end
			
			-- Обработка клика по игроку в списке
			btn.Activated:Connect(function()
				selectedPlayerName = p.Name
				tpLabel.Text = "Teleport to: " .. p.DisplayName
				refreshPlayerList() -- Перерисовываем список, чтобы подсветить выбранного
			end)
		end
	end
end

refreshBtn.Activated:Connect(refreshPlayerList)

