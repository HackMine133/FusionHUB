-- 8. ДИНАМИЧЕСКОЕ ЯДРО АИМБОТА И ФУНКЦИЯ ПРОВЕРКИ СТЕН
-- ==========================================
local function isVisible(targetPart, targetChar, currentCamera)
	if not aimSettings.WallCheck then return true end
	
	local localChar = player.Character
	if not localChar then return false end

	local rayOrigin = currentCamera.CFrame.Position
	local rayDirection = targetPart.Position - rayOrigin

	local rayParams = RaycastParams.new()
	rayParams.FilterDescendantsInstances = {localChar, currentCamera}
	rayParams.FilterType = Enum.RaycastFilterType.Exclude
	rayParams.IgnoreWater = true

	local rayResult = Workspace:Raycast(rayOrigin, rayDirection, rayParams)
	
	if rayResult then
		if rayResult.Instance:IsDescendantOf(targetChar) then
			return true
		end
		return false
	end
	
	return true
end

local function getTargetPart(char)
	local part = nil
	if aimSettings.AimPart == "Head" then
		part = char:FindFirstChild("Head") or char:FindFirstChild("HumanoidRootPart") or char.PrimaryPart
	else
		part = char:FindFirstChild("HumanoidRootPart") or char:FindFirstChild("Torso") or char:FindFirstChild("UpperTorso") or char.PrimaryPart
	end
	
	return part or char:FindFirstChildWhichIsA("BasePart")
end

local function getClosestPlayer()
	local closestPlayer = nil
	local shortestDistance = aimSettings.FOVRadius
	local mouseLocation = UserInputService:GetMouseLocation()
	
	local currentCamera = Workspace.CurrentCamera 
	if not currentCamera then return nil end
	
	for _, v in pairs(Players:GetPlayers()) do
		if v ~= player then
			if aimSettings.TeamCheck and v.Team == player.Team then continue end
			if aimSettings.TargetTeam ~= "All" and (not v.Team or v.Team.Name ~= aimSettings.TargetTeam) then continue end
			
			-- =========================================
			-- ИНТЕГРАЦИЯ WHITELIST: ИГНОРИРУЕМ ИГРОКОВ В СПИСКЕ
			-- =========================================
			if _G.FusionHubWhitelistEnabled and _G.FusionHubWhitelist then
				local isWhitelisted = false
				for _, wlName in ipairs(_G.FusionHubWhitelist) do
					if v.Name == wlName then 
						isWhitelisted = true 
						break 
					end
				end
				if isWhitelisted then continue end
			end
			-- =========================================
			
			local char = v.Character
			if char then
				local humanoid = char:FindFirstChildWhichIsA("Humanoid")
				local isAlive = true
				if humanoid then 
					isAlive = humanoid.Health > 0 
				end
				
				if isAlive then
					-- Проверка на ForceField
					if aimSettings.IgnoreFF and char:FindFirstChildWhichIsA("ForceField") then
						continue -- Пропускаем игрока, пока у него есть бессмертие
					end
					
					local targetPart = getTargetPart(char)
					
					if targetPart then
						local vector, onScreen = currentCamera:WorldToViewportPoint(targetPart.Position)
						
						if onScreen and isVisible(targetPart, char, currentCamera) then
							local distance = (Vector2.new(mouseLocation.X, mouseLocation.Y) - Vector2.new(vector.X, vector.Y)).Magnitude
							
							if distance < shortestDistance then
								closestPlayer = char
								shortestDistance = distance
							end
						end
					end
				end
			end
		end
	end
	
	return closestPlayer
end

-- ==========================================
-- 9. ОСНОВНОЙ ПЕРЕКЛЮЧАТЕЛЬ АИМБОТА
-- ==========================================
aimBtn.Activated:Connect(function()
	aimSettings.Enabled = not aimSettings.Enabled
	
	if aimSettings.Enabled then
		aimLabel.Text = "Aimbot: ON"
		aimLabel.TextColor3 = Color3.fromRGB(150, 255, 150)
		aimBtn.BackgroundColor3 = Color3.fromRGB(35, 50, 35)
		
		RunService:BindToRenderStep("FusionHubAimbotPriority", Enum.RenderPriority.Camera.Value + 200, function()
			if isAiming then
				pcall(function()
					local targetChar = getClosestPlayer()
					local currentCamera = Workspace.CurrentCamera 
					
					if targetChar and currentCamera then
						local targetPart = getTargetPart(targetChar)
						if targetPart then
							if (currentCamera.CFrame.Position - targetPart.Position).Magnitude > 0.1 then
								local targetCFrame = CFrame.new(currentCamera.CFrame.Position, targetPart.Position)
								currentCamera.CFrame = currentCamera.CFrame:Lerp(targetCFrame, aimSettings.Smoothness)
							end
						end
						
						-- Логика Авто-выстрела (Hold или Spam)
						if aimSettings.AutoShoot then
							if aimSettings.AutoShootMode == "Hold" then
								if not isShooting and mouse1press then
									mouse1press()
									isShooting = true
								end
							elseif aimSettings.AutoShootMode == "Spam" then
								if mouse1click then
									mouse1click()
								elseif mouse1press and mouse1release then
									mouse1press()
									task.spawn(function()
										task.wait()
										mouse1release()
									end)
								end
								isShooting = true
							end
						end
					else
						-- Если цель пропала/умерла, отпускаем ЛКМ (сброс)
						if isShooting and mouse1release then
							mouse1release()
							isShooting = false
						end
					end
				end)
			else
				-- Если мы перестали целиться вручную
				if isShooting and mouse1release then
					pcall(mouse1release)
					isShooting = false
				end
			end
		end)
	else
		aimLabel.Text = "Aimbot: OFF"
		aimLabel.TextColor3 = Color3.fromRGB(240, 240, 245)
		aimBtn.BackgroundColor3 = Color3.fromRGB(30, 30, 35)
		isAiming = false
		
		-- Отпускаем ЛКМ при отключении аимбота
		if isShooting and mouse1release then
			pcall(mouse1release)
			isShooting = false
		end
		
		pcall(function() RunService:UnbindFromRenderStep("FusionHubAimbotPriority") end)
	end
end)
