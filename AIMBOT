local draggingAim, dragInputAim, dragStartAim, startPosAim
aimMenu.InputBegan:Connect(function(input)
	if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
		draggingAim = true
		dragStartAim = input.Position
		startPosAim = aimMenu.Position
		input.Changed:Connect(function()
			if input.UserInputState == Enum.UserInputState.End then draggingAim = false end
		end)
	end
end)

aimMenu.InputChanged:Connect(function(input)
	if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then
		dragInputAim = input
	end
end)

UserInputService.InputChanged:Connect(function(input)
	if input == dragInputAim and draggingAim then
		local delta = input.Position - dragStartAim
		TweenService:Create(aimMenu, TweenInfo.new(0.08, Enum.EasingStyle.Sine, Enum.EasingDirection.Out), {
			Position = UDim2.new(startPosAim.X.Scale, startPosAim.X.Offset + delta.X, startPosAim.Y.Scale, startPosAim.Y.Offset + delta.Y)
		}):Play()
	end
end)

