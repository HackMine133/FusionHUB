-- 7. ОБРАБОТКА ВВОДА (БИНДЫ И РЕЖИМЫ)
-- ==========================================
local function handleInputMatch(input)
	if input.UserInputType == Enum.UserInputType.Keyboard and aimSettings.Bind == input.KeyCode then return true end
	if (input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.MouseButton2 or input.UserInputType == Enum.UserInputType.MouseButton3) and aimSettings.Bind == input.UserInputType then return true end
	return false
end

UserInputService.InputBegan:Connect(function(input, gameProcessed)
	if waitBind then
		if input.UserInputType == Enum.UserInputType.Keyboard then
			aimSettings.Bind = input.KeyCode
			bindBtn.Text = "Bind: " .. input.KeyCode.Name
			bindBtn.TextColor3 = Color3.fromRGB(200, 200, 205)
			waitBind = false
		elseif input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.MouseButton2 or input.UserInputType == Enum.UserInputType.MouseButton3 then
			aimSettings.Bind = input.UserInputType
			bindBtn.Text = "Bind: " .. input.UserInputType.Name
			bindBtn.TextColor3 = Color3.fromRGB(200, 200, 205)
			waitBind = false
		end
		return
	end
	
	if not aimSettings.Enabled then return end
	
	if handleInputMatch(input) then
		if aimSettings.Mode == "Toggle" then
			isAiming = not isAiming
		elseif aimSettings.Mode == "Hold" then
			isAiming = true
		end
	end
end)

UserInputService.InputEnded:Connect(function(input, gameProcessed)
	if waitBind or not aimSettings.Enabled then return end
	
	if aimSettings.Mode == "Hold" and handleInputMatch(input) then
		isAiming = false
	end
end)

