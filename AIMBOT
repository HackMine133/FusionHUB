createSettingsBtn("Target Team: All", 165, function(btn)
	local availableTeams = {"All"}
	local foundTeams = {}
	
	for _, team in ipairs(Teams:GetTeams()) do
		if not foundTeams[team.Name] then
			foundTeams[team.Name] = true
			table.insert(availableTeams, team.Name)
		end
	end
	
	for _, p in ipairs(Players:GetPlayers()) do
		if p.Team and p.Team.Name ~= "" then
			if not foundTeams[p.Team.Name] then
				foundTeams[p.Team.Name] = true
				table.insert(availableTeams, p.Team.Name)
			end
		end
	end
	
	local currentIndex = 1
	for i, teamName in ipairs(availableTeams) do
		if teamName == aimSettings.TargetTeam then
			currentIndex = i
			break
		end
	end
	
	local nextIndex = currentIndex + 1
	if nextIndex > #availableTeams then nextIndex = 1 end
	
	aimSettings.TargetTeam = availableTeams[nextIndex]
	
	if aimSettings.TargetTeam == "All" then
		btn.Text = "Target Team: All"
		btn.TextColor3 = Color3.fromRGB(200, 200, 205)
	else
		btn.Text = "Target Team: " .. aimSettings.TargetTeam
		btn.TextColor3 = Color3.fromRGB(255, 180, 100)
	end
end)

