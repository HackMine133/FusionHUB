-- ==========================================
-- 7. ЛОГИКА И АНИМАЦИИ МЕНЮ НАСТРОЕК
-- ==========================================
local isSettingsOpen = false

settingsBtn.Activated:Connect(function()
	isSettingsOpen = not isSettingsOpen
	if isSettingsOpen then
		flyMenu.Visible = true
		TweenService:Create(flyMenu, TweenInfo.new(0.3, Enum.EasingStyle.Cubic, Enum.EasingDirection.Out), {
			GroupTransparency = 0
		}):Play()
	else
		local closeTween = TweenService:Create(flyMenu, TweenInfo.new(0.2, Enum.EasingStyle.Cubic, Enum.EasingDirection.In), {
			GroupTransparency = 1
		})
		closeTween:Play()
		closeTween.Completed:Wait()
		if not isSettingsOpen then
			flyMenu.Visible = false
		end
	end
end)

-- Обновление скорости из поля ввода
speedBox.FocusLost:Connect(function()
	local num = tonumber(speedBox.Text)
	if num then
		flySettings.Speed = num
	else
		-- Если ввели буквы, возвращаем старое значение
		speedBox.Text = tostring(flySettings.Speed)
	end
end)

-- Система перетаскивания (Drag)
local draggingFly, dragInputFly, dragStartFly, startPosFly
flyMenu.InputBegan:Connect(function(input)
	if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
		draggingFly = true
		dragStartFly = input.Position
		startPosFly = flyMenu.Position
		input.Changed:Connect(function()
			if input.UserInputState == Enum.UserInputState.End then draggingFly = false end
		end)
	end
end)

flyMenu.InputChanged:Connect(function(input)
	if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then
		dragInputFly = input
	end
end)

UserInputService.InputChanged:Connect(function(input)
	if input == dragInputFly and draggingFly then
		local delta = input.Position - dragStartFly
		TweenService:Create(flyMenu, TweenInfo.new(0.08, Enum.EasingStyle.Sine, Enum.EasingDirection.Out), {
			Position = UDim2.new(startPosFly.X.Scale, startPosFly.X.Offset + delta.X, startPosFly.Y.Scale, startPosFly.Y.Offset + delta.Y)
		}):Play()
	end
end)

-- ==========================================
-- 8. ЛОГИКА ПОЛЕТА
-- ==========================================
local function stopFlying()
	if flyConnection then
		flyConnection:Disconnect()
		flyConnection = nil
	end
	if bodyVelocity then bodyVelocity:Destroy() bodyVelocity = nil end
	if bodyGyro then bodyGyro:Destroy() bodyGyro = nil end
	
	if player.Character and player.Character:FindFirstChildOfClass("Humanoid") then
		player.Character:FindFirstChildOfClass("Humanoid").PlatformStand = false
	end
end

local function toggleFly()
	flySettings.Enabled = not flySettings.Enabled
	
	if flySettings.Enabled then
		-- Визуальное включение
		flyLabel.Text = "Fly: ON"
		flyLabel.TextColor3 = Color3.fromRGB(150, 255, 150)
		flyBtn.BackgroundColor3 = Color3.fromRGB(35, 50, 35)
		
		local char = player.Character
		if not char or not char:FindFirstChild("HumanoidRootPart") then return end
		local hrp = char:FindFirstChild("HumanoidRootPart")
		local humanoid = char:FindFirstChildOfClass("Humanoid")
		
		-- Убираем анимацию ходьбы/падения
		if humanoid then humanoid.PlatformStand = true end
		
		-- Создаем "моторы" для полета
		bodyVelocity = Instance.new("BodyVelocity")
		bodyVelocity.MaxForce = Vector3.new(9e9, 9e9, 9e9)
		bodyVelocity.Velocity = Vector3.zero
		bodyVelocity.Parent = hrp
		
		-- BodyGyro заставляет персонажа смотреть в определенную сторону (по камере)
		bodyGyro = Instance.new("BodyGyro")
		bodyGyro.MaxTorque = Vector3.new(9e9, 9e9, 9e9)
		bodyGyro.P = 9e4
		bodyGyro.CFrame = workspace.CurrentCamera.CFrame
		bodyGyro.Parent = hrp
		
		-- Цикл обработки направления и скорости
		flyConnection = RunService.RenderStepped:Connect(function()
			if not char or not char:FindFirstChild("HumanoidRootPart") or not humanoid or humanoid.Health <= 0 then
				toggleFly() -- Безопасное авто-отключение при смерти
				return
			end
			
			local cam = workspace.CurrentCamera
			local moveDir = Vector3.zero
			
			-- Считываем нажатия клавиш (WASD + Space + LCtrl)
			if UserInputService:IsKeyDown(Enum.KeyCode.W) then moveDir += cam.CFrame.LookVector end
			if UserInputService:IsKeyDown(Enum.KeyCode.S) then moveDir -= cam.CFrame.LookVector end
			if UserInputService:IsKeyDown(Enum.KeyCode.D) then moveDir += cam.CFrame.RightVector end
			if UserInputService:IsKeyDown(Enum.KeyCode.A) then moveDir -= cam.CFrame.RightVector end
			if UserInputService:IsKeyDown(Enum.KeyCode.Space) then moveDir += Vector3.new(0, 1, 0) end
			if UserInputService:IsKeyDown(Enum.KeyCode.LeftControl) then moveDir -= Vector3.new(0, 1, 0) end
			
			-- Нормализация вектора, чтобы по диагонали скорость не умножалась
			if moveDir.Magnitude > 0 then
				moveDir = moveDir.Unit
			end
			
			-- Применяем скорость
			bodyVelocity.Velocity = moveDir * flySettings.Speed
			
			-- Персонаж всегда смотрит туда, куда смотрит камера
			bodyGyro.CFrame = cam.CFrame
		end)
		
	else
		-- Визуальное выключение
		flyLabel.Text = "Fly: OFF"
		flyLabel.TextColor3 = Color3.fromRGB(240, 240, 245)
		flyBtn.BackgroundColor3 = Color3.fromRGB(30, 30, 35)
		
		stopFlying()
	end
end

flyBtn.Activated:Connect(toggleFly)

-- Защита от багов при перерождении (как в твоем Noclip)
player.CharacterAdded:Connect(function()
	if flySettings.Enabled then
		toggleFly() 
	end
end)
