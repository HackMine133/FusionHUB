local function createSpeedBtn(speedValue, displayName)
	local btn = Instance.new("TextButton")
	btn.Size = UDim2.new(0, 45, 0, 30)
	btn.BackgroundColor3 = Color3.fromRGB(35, 35, 40)
	btn.Text = displayName
	btn.Font = Enum.Font.GothamBold
	btn.TextColor3 = Color3.fromRGB(255, 255, 255)
	btn.TextSize = 12
	btn.Active = true
	btn.Parent = speedsFrame
	
	local btnRound = Instance.new("UICorner")
	btnRound.CornerRadius = UDim.new(0, 6)
	btnRound.Parent = btn
	
	btn.Activated:Connect(function()
		flySettings.Speed = speedValue
		speedBox.Text = tostring(speedValue)
	end)
end

